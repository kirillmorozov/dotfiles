#!/usr/bin/env fish

# Oh-My-Zsh brew plugin abbreviations.
# Source: https://github.com/ohmyzsh/ohmyzsh/blob/master/plugins/brew/brew.plugin.zsh

abbr -a ba -- 'brew autoremove'
abbr -a bcn -- 'brew cleanup'
abbr -a bdr -- 'brew doctor'
abbr -a bi -- 'brew install'
abbr -a bl -- 'brew list'
abbr -a bo -- 'brew outdated'
abbr -a br -- 'brew reinstall'
abbr -a bs -- 'brew search'
abbr -a bu -- 'brew update'
abbr -a bubo -- 'brew update; and brew outdated'
abbr -a bubu -- 'brew update; and brew outdated; and brew upgrade'
abbr -a bup -- 'brew upgrade'
