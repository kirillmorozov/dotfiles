#!/usr/bin/env fish

# Oh-My-Zsh dnf plugin abbreviations.
# Source: https://github.com/ohmyzsh/ohmyzsh/blob/master/plugins/dnf/dnf.plugin.zsh

abbr -a dnfc -- "sudo dnf clean all"
abbr -a dnfi -- "sudo dnf install"
abbr -a dnfl -- "dnf list"
abbr -a dnfli -- "dnf list installed"
abbr -a dnfp -- "dnf info"
abbr -a dnfr -- "sudo dnf remove"
abbr -a dnfs -- "dnf search"
abbr -a dnfu -- "sudo dnf upgrade"
